###############################################################################
# Property Manager — environment configuration
# Copy to .env and fill in. Generate secrets with:  npm run bootstrap
###############################################################################

# --- Phase 1: core (required) ------------------------------------------------
NODE_ENV=production

# App database (the docker-compose `db` service). For local dev outside Docker,
# point this at your local Postgres.
POSTGRES_USER=pm
POSTGRES_PASSWORD=change-me
POSTGRES_DB=property_manager
DATABASE_URL="postgresql://pm:change-me@db:5432/property_manager?schema=public"

# Public URL of the app (used for OIDC callbacks, setup/emergency links).
APP_URL="https://pm.example.com"
APP_PORT=3000

# Auth.js session signing secret (32+ random bytes). Generated by `npm run bootstrap`.
AUTH_SECRET=
# Trust the X-Forwarded-* headers from your reverse proxy (required behind a proxy).
AUTH_TRUST_HOST=true
# How many trusted proxy hops sit in front (for real client IP in rate limiting).
TRUSTED_PROXY_COUNT=1

# AES-256-GCM key-encryption-key for the OIDC client secret at rest (32 bytes,
# base64 or hex). Generated by `npm run bootstrap`. BACK THIS UP — losing it makes
# the stored OIDC secret unrecoverable (env fallback still works).
SETTINGS_ENC_KEY=

# First-run /setup gate. Generated by `npm run bootstrap`. Required to create the
# first owner; visit ${APP_URL}/setup?token=${SETUP_BOOTSTRAP_TOKEN}.
SETUP_BOOTSTRAP_TOKEN=

# Seed sample data on first container start (dev/demo only).
SEED_ON_START=false

# Billing worker schedule (cron). Default: daily at 01:00.
BILLING_CRON=0 1 * * *

# Defaults applied when creating new properties.
DEFAULT_TIMEZONE=America/New_York
DEFAULT_CURRENCY=USD

# --- Auth: OIDC (Authentik) --------------------------------------------------
# Preferred: configure OIDC in the web UI (Settings → Authentication), stored
# encrypted in the DB. These env vars are a fallback used when the DB config is
# absent (e.g. bootstrap/CI). DB config takes precedence when enabled.
# AUTHENTIK_ISSUER="https://auth.example.com/application/o/property-manager/"
# AUTHENTIK_CLIENT_ID=
# AUTHENTIK_CLIENT_SECRET=
OIDC_SCOPES="openid email profile"
# Allow the `owner` role to be granted from an Authentik group (off by default).
ALLOW_OWNER_FROM_GROUP=false

# Break-glass emergency login. Off by default; provision with `npm run breakglass issue`.
# (Env override forces it on and bypasses auto-expiry — use only during recovery.)
BREAK_GLASS=false

# --- Authentik stack (docker compose --profile idp) --------------------------
AUTHENTIK_TAG=2025.2
AUTHENTIK_SECRET_KEY=
AUTHENTIK_PG_PASS=
AUTHENTIK_PORT=9000
AUTHENTIK_PORT_HTTPS=9443

# --- Phase 2: file storage (docker compose --profile storage) ----------------
# "local" stores uploads on the app server's disk (single-node installs; simplest).
# "s3" works with AWS/R2/B2/MinIO. "stub" disables uploads.
# STORAGE_PROVIDER=s3
# S3_ENDPOINT="http://minio:9000"
# S3_REGION=us-east-1
# S3_BUCKET=receipts
# S3_ACCESS_KEY_ID=minioadmin
# S3_SECRET_ACCESS_KEY=minioadmin
# S3_FORCE_PATH_STYLE=true
STORAGE_PROVIDER=stub
# Directory for STORAGE_PROVIDER=local (relative to the app working directory).
LOCAL_STORAGE_DIR=.data/uploads

# --- Phase 3: SMS provider ---------------------------------------------------
# SMS_PROVIDER=twilio
# SMS_ACCOUNT_SID=
# SMS_AUTH_TOKEN=
# SMS_FROM_NUMBER=
SMS_PROVIDER=stub
# Scheduled-reminder sweep (cron, worker process) and the due-soon window.
REMINDER_CRON=0 9 * * *
REMINDER_DUE_SOON_DAYS=3

# --- Phase 5: OCR ------------------------------------------------------------
OCR_ENABLED=false
# OCR_PROVIDER=

# --- Reverse proxy (docker compose --profile proxy) --------------------------
# APP_DOMAIN=pm.example.com
