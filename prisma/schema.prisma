// Rental Property Management Platform — data model.
//
// Conventions:
//   * All money is stored as signed integer minor units (cents) in BIGINT (Prisma `BigInt`),
//     in fields suffixed `Cents`. Never floats. See lib/money.ts and docs/accounting.md.
//   * LedgerEntry is the single source of financial truth. Balance = SUM(amountCents) over
//     ALL physical rows for a lease (immutable, append-only). Corrections are offsetting
//     `reversal` entries — entries are never deleted or mutated for balance purposes.
//   * Phase 2/3 models (Receipt, UploadedDocument, Reminder) are committed now but unused in
//     Phase 1, so later phases attach without a destructive migration on live financial data.

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Role {
  owner
  admin
  finance // CFO-style: manager powers + billing-rate settings, no operational/auth settings
  manager
  viewer
}

enum UnitType {
  apartment
  house
  duplex
  storage
  commercial
  other
}

// Manual serviceability of a unit. Occupancy ("leased or not") is derived from
// the active Lease, never stored — so a unit can't show two contradictory states.
enum ServiceStatus {
  in_service
  maintenance
  unavailable
}

enum LeaseStatus {
  draft
  active
  ended
  eviction
  month_to_month
}

enum LateFeeType {
  none
  fixed
  percentage
  daily // lateFeeAmountCents per day past grace, optional lateFeeMaxCents cap
}

enum PaymentMethod {
  cash
  check
  money_order
  card
  ach
  online
  cash_app
  other
}

enum PaymentStatus {
  pending
  posted
  voided
  reversed
}

enum LedgerEntryType {
  rent_charge
  payment
  late_fee
  adjustment
  credit
  reversal
}

enum AuditActorType {
  user
  breakglass
  system
}

// Phase 2 / 3 enums
enum ReceiptType {
  digital
  uploaded_paper
}

enum SentMethod {
  sms
  email
  printed
  not_sent
}

enum UploadType {
  receipt_photo
  lease
  lease_template // .docx with {{placeholders}}, filled per lease
  tenant_document
  other
  email_attachment // file pulled off an inbound email (module "mailbox")
  public_site // marketing photo shown on the public site (module "publicSite")
  condition_photo // dated unit move-in/move-out/turnover condition photo (module "inspections")
  inspection_photo // photo attached to a single inspection checklist item (module "inspections")
}

enum ReminderType {
  rent_due_soon
  rent_overdue
  partial_balance
  payment_receipt
  manual
  maintenance
}

enum ReminderStatus {
  queued
  sent
  delivered
  failed
}

/// Delivery channel for reminders / notifications. Consent is absolute and
/// tracked per channel (smsConsent / emailConsent on Tenant).
enum NotificationChannel {
  sms
  email
}

// ---------------------------------------------------------------------------
// Auth / identity
// ---------------------------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(viewer)
  isActive      Boolean   @default(true)
  // Bumped to invalidate outstanding JWTs (role change, disable, break-glass use).
  securityStamp String    @default(cuid())
  // Staff notifications (self-service at Settings → Notifications; admins can
  // edit anyone's from Settings → Users). Digests go to manager+ roles by
  // email; phone enables SMS for the urgent cash-pickup alerts.
  phone                   String?
  notifyOverdueDigest     Boolean @default(true)
  notifyMaintenanceDigest Boolean @default(true)
  notifyLeaseExpiration   Boolean @default(true)
  notifyCashPickup        Boolean @default(true)
  // Personal dashboard layout: { order: string[], collapsed: {id:true} }.
  // Per-user UI preference only — resolved/clamped to known sections in
  // lib/dashboard/layout.ts; never security-relevant.
  dashboardLayout Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

/// Single-row table (id is always "singleton") holding web-editable OIDC config.
/// The client secret is AES-256-GCM encrypted at rest (ciphertext + nonce + tag + key version).
model AuthSettings {
  id                         String    @id @default("singleton")
  oidcEnabled                Boolean   @default(false)
  oidcIssuer                 String?
  oidcClientId               String?
  oidcClientSecretCiphertext String?
  oidcClientSecretNonce      String?
  oidcClientSecretTag        String?
  oidcSecretKeyVersion       Int       @default(1)
  oidcScopes                 String    @default("openid email profile")
  // JSON map of Authentik group name -> Role, e.g. {"managers":"manager"}.
  groupMappings              Json      @default("{}")
  allowOwnerFromGroup        Boolean   @default(false)
  breakGlassEnabled          Boolean   @default(false)
  breakGlassExpiresAt        DateTime?
  updatedBy                  String?
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt
}

/// Single-row app-level settings: white-labeling, messaging, org defaults.
/// Mirrors AuthSettings: DB config wins, env is the fallback; the Twilio auth
/// token is AES-256-GCM encrypted at rest with SETTINGS_ENC_KEY.
model AppSettings {
  id                String  @id @default("singleton")
  // Organization / white-label (header, receipts, reports)
  businessName      String?
  businessLegalName String?
  businessAddress   String? // multiline
  businessPhone     String?
  businessEmail     String?
  logoDocumentId    String? // UploadedDocument.id (loose ref)
  // H1: brand accent colour (hex). Only its OKLCH hue is used — the app shell
  // re-tints --primary/--ring (lib/config/brand.ts); null/blank -> shipped theme.
  brandColor        String?
  receiptFooter     String? // free text printed at the bottom of receipts
  // Receipt number prefix ("RCT-YYYYMMDD-NNNN"); null/blank -> "RCT".
  // Sanitized to A-Z/0-9, max 8 (lib/accounting/receipts.ts).
  receiptPrefix     String?
  // Tenant-facing free text (branded, whitespace-pre-wrap), null -> shipped copy.
  portalWelcomeText String? // shown on the tenant portal home
  applyIntroText    String? // shown atop the public /apply form
  // H5: tenant-facing "how to pay" copy (portal home) + the post-submit
  // confirmation shown on the public /apply form. null/blank -> shipped copy.
  portalPaymentHelpText String?
  applyConfirmationText String?
  // H3: free-text header block printed atop reports and receipts (e.g. a report
  // subtitle or a "remit to" address); null/blank -> nothing rendered.
  reportHeaderText String?
  // H2: default DataTable page size (one of 10/20/50); null/invalid -> 10.
  defaultTablePageSize Int?
  // File storage — NON-SECRET config, DB-over-env (mirrors the SMS pattern).
  // null/blank on each -> the env value. Secrets (S3 keys, STORAGE_ENC_KEY) and
  // the local dir / encrypt flag stay env-only. See lib/services/storage-config.ts.
  storageProvider   String?  // "stub" | "local" | "s3"; null -> STORAGE_PROVIDER
  s3Bucket          String?
  s3Region          String?
  s3Endpoint        String?
  s3ForcePathStyle  Boolean? // null -> S3_FORCE_PATH_STYLE
  // Defaults applied when creating new properties (override env defaults)
  defaultTimezone   String?
  defaultCurrency   String?
  // Messaging (SMS). smsProvider null -> env config; "stub" | "twilio" -> DB.
  smsEnabled              Boolean @default(true) // master switch for ALL sends
  smsProvider             String?
  smsAccountSid           String?
  smsAuthTokenCiphertext  String?
  smsAuthTokenNonce       String?
  smsAuthTokenTag         String?
  smsFromNumber           String?
  reminderDueSoonDays     Int? // null -> env REMINDER_DUE_SOON_DAYS
  // H4: hour of day (0-23, server local) the worker runs the daily reminder +
  // digest sweeps; null -> env REMINDER_CRON (default 09:00).
  reminderSendHour        Int?
  dueSoonRemindersEnabled Boolean @default(true)
  overdueRemindersEnabled Boolean @default(true)
  // Window (days) for the lease-expiration alert: the dashboard "Lease
  // expirations" section and the weekly staff expiration digest both surface
  // active leases ending within this many days. null -> the shipped default
  // (UPCOMING_DAYS = 60); clamped to 1..365 (lib/leases/expiration.ts).
  leaseExpirationAlertDays Int?
  // Per-type SMS template overrides: { "rent_overdue": "body...", ... }
  smsTemplates Json @default("{}")
  // Per-type EMAIL subject-line overrides (the email channel; bodies reuse the
  // shared templates). { "rent_overdue": "subject...", ... }; blank -> default.
  emailSubjects Json @default("{}")

  // 10DLC / A2P messaging compliance. Privacy policy and terms can be hosted
  // in-app — the *Text fields render at the public /privacy and /terms routes
  // (whitespace-pre-wrap, branded) — or pointed at an externally-hosted page
  // via the *Url override, which wins when set. (The 10DLC "sample embedded
  // link" is not stored — it is a prefilled dead link derived from APP_URL;
  // see lib/config/compliance.ts.) None of these touch the ledger or tenant data.
  privacyPolicyText String?
  privacyPolicyUrl  String?
  termsText         String?
  termsUrl          String?

  // Public marketing site (module "publicSite") served at the public host
  // (e.g. newedgerentals.com): operator-authored splash copy; null/blank ->
  // shipped fallback. publicSiteUrl is the public base URL so tenant portal
  // invite/reset links point at the public brand, not the staff host.
  publicSiteUrl     String?
  publicSiteTagline String?
  publicSiteIntro   String?
  publicSiteAreas   String?
  publicSiteHours   String?
  // Richer marketing content (all operator-edited at Settings → Public site):
  // an amenities list (one per line), a hero/banner image + a photo gallery
  // (UploadedDocument ids; served publicly via /welcome/photo/[id]), and a
  // toggle to show live current-availability (vacant units) on the site.
  publicSiteAmenities      String?
  publicSiteHeroDocumentId String? // UploadedDocument.id (loose ref), uploadType "public_site"
  publicSiteGallery        Json    @default("[]") // [{ "id": "<UploadedDocument.id>" }, ...]
  publicSiteShowAvailability Boolean @default(false)
  // Master switch for the dedicated public /vacancies browse page (gallery of
  // available + upcoming-vacant units with filters + an Apply CTA). Defaults on;
  // the page also requires the publicSite module to be enabled.
  showVacancies            Boolean @default(true)

  // Email (SMTP). DB-only config — no env fallback. emailProvider null ->
  // not configured; "stub" logs only; "smtp" sends. Auth is either a password
  // or OAuth2 (XOAUTH2: Gmail / Microsoft 365); all three secrets are
  // AES-256-GCM encrypted with SETTINGS_ENC_KEY (field-bound AAD).
  emailEnabled     Boolean @default(false) // master switch for ALL email sends
  emailProvider    String?
  emailFromAddress String?
  emailFromName    String?
  emailSmtpHost    String?
  emailSmtpPort    Int?
  emailSmtpSecure  Boolean @default(true) // implicit TLS (465); off = STARTTLS (587)
  emailSmtpUser    String?
  emailAuthMethod  String? // "password" | "oauth2"
  emailPasswordCiphertext String?
  emailPasswordNonce      String?
  emailPasswordTag        String?
  emailOauthClientId      String?
  // OAuth2 token endpoint; null -> Gmail's. Microsoft 365:
  // https://login.microsoftonline.com/<tenant>/oauth2/v2.0/token
  emailOauthTokenUrl               String?
  emailOauthClientSecretCiphertext String?
  emailOauthClientSecretNonce      String?
  emailOauthClientSecretTag        String?
  emailOauthRefreshTokenCiphertext String?
  emailOauthRefreshTokenNonce      String?
  emailOauthRefreshTokenTag        String?

  // Inbound email (module "mailbox"): capture a mailbox via IMAP into a staff
  // inbox for invoices/receipts (→ a reviewed PropertyExpense) and
  // correspondence. DB-only config (no env fallback). inboxProvider null ->
  // not configured; "stub" injects canned messages; "imap" polls a real mailbox
  // in the worker. Microsoft 365 disables IMAP Basic Auth, so auth is either a
  // "password" (self-hosted / Gmail app password) or "oauth2" (XOAUTH2:
  // client-credentials app-only, or a refresh token). All three secrets are
  // AES-256-GCM encrypted with SETTINGS_ENC_KEY (field-bound AAD).
  inboxEnabled            Boolean @default(false) // master switch for polling
  inboxProvider           String? // null | "stub" | "imap"
  inboxImapHost           String?
  inboxImapPort           Int?
  inboxImapSecure         Boolean @default(true) // implicit TLS (993)
  inboxImapUser           String? // the mailbox address that is polled
  inboxFolder             String? // null/blank -> "INBOX"
  inboxAuthMethod         String? // "password" | "oauth2"
  inboxPasswordCiphertext String?
  inboxPasswordNonce      String?
  inboxPasswordTag        String?
  inboxOauthClientId      String?
  // OAuth2 token endpoint, e.g. Microsoft 365:
  // https://login.microsoftonline.com/<tenant>/oauth2/v2.0/token
  inboxOauthTokenUrl      String?
  // OAuth2 scope; null/blank -> https://outlook.office365.com/.default
  inboxOauthScope         String?
  inboxOauthClientSecretCiphertext String?
  inboxOauthClientSecretNonce      String?
  inboxOauthClientSecretTag        String?
  // Present -> refresh_token grant (delegated); absent -> client_credentials.
  inboxOauthRefreshTokenCiphertext String?
  inboxOauthRefreshTokenNonce      String?
  inboxOauthRefreshTokenTag        String?
  // Interactive "Connect" flow: which provider issued the stored refresh token
  // ("microsoft" | "google") and the Microsoft tenant — so the redirect flow can
  // rebuild the authorize/token URLs and the UI can show the connection.
  inboxOauthProvider               String?
  inboxOauthTenant                 String?
  // Poll health: the worker writes the outcome of each poll here so Settings →
  // Email inbox can show whether polling is actually running, without server logs.
  inboxLastPolledAt    DateTime? // last poll ATTEMPT (success or fail) — proves the worker is alive
  inboxLastFetched     Int? // counts from the last SUCCESSFUL poll
  inboxLastProcessed   Int?
  inboxLastFailed      Int?
  inboxLastError       String? // last error message; cleared on a successful poll
  inboxLastErrorAt     DateTime?

  // Role -> capability overrides vs. the default hierarchy, e.g.
  // { "viewer": { "reports.view": true }, "manager": { "payments.manage": false } }.
  // Empty object == the built-in defaults (see lib/auth/permissions.ts).
  rolePermissions Json @default("{}")

  // Optional feature modules, e.g. { "financials": true, "maintenance": false }.
  // Missing keys use the built-in defaults (lib/services/app-settings.ts).
  // Disabling a module hides its UI but never deletes its data.
  modules Json @default("{}")

  // Public rental-application form config: which fields show + are required,
  // e.g. { "monthlyIncome": "required", "employer": "hidden" }. Missing keys use
  // the defaults in lib/applications/form-config.ts. Editable at Settings →
  // Applications. Name is always required; email/phone can't both be hidden.
  applicationFields Json @default("{}")

  // Operator-defined custom application question sections (beyond the fixed
  // fields above): an array of { id, title, description, questions:[{ id,
  // label, type, required, options }] }. Sanitized by
  // lib/applications/custom-questions.ts (resolveCustomSections). Editable at
  // Settings → Applications.
  applicationCustomSections Json @default("[]")

  // Built-in lease-agreement clause text ({{placeholder}} template) rendered
  // on the printable agreement page; null -> the shipped default.
  leaseAgreementText String?

  // Saved landlord signature, auto-applied to outgoing e-sign requests by
  // managers+ (esign.manage). Image is a storage key (drawn PNG); name is the
  // typed signature line. Initials image is optional — when absent, typed
  // initials are derived from landlordSignatureName at {{landlord_initials}}.
  landlordSignatureName     String?
  landlordSignatureImageKey String?
  landlordInitialsImageKey  String?

  // Cash App: org cashtag (e.g. "$NewEdgeRentals") surfaced as the
  // {{cash_app_tag}}/{{cash_app_link}} template variables and in the tenant
  // portal's "how to pay" panel. Manual recording only — Cash App has no API.
  cashAppCashtag String?

  // Org-wide charge defaults ("rates"), editable in Settings -> Billing
  // (finance+). Prefill new leases/units; an explicit bulk action can apply
  // grace/late-fee terms to existing active leases.
  defaultDueDay             Int?
  defaultGraceDays          Int?
  defaultLateFeeType        LateFeeType?
  defaultLateFeeAmountCents BigInt?
  defaultLateFeeBps         Int?
  defaultLateFeeMaxCents    BigInt?
  defaultInternetFeeCents   BigInt?

  updatedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// A standing request to email a portfolio report on a cadence. The worker's
/// weekly/monthly sweep renders the named report in the chosen format and emails
/// it to `recipientEmails`, then stamps `lastSentAt`. Pure config / delivery
/// metadata — it never touches the ledger. `reportType` is one of the registry
/// slugs (lib/services/report-registry.ts); `format` is csv|pdf|xlsx; `cadence`
/// is weekly|monthly. Recipients are stored as a comma-separated string (parsed
/// + validated on save) to keep the table portable.
model ReportSchedule {
  id              String    @id @default(cuid())
  reportType      String
  format          String // csv | pdf | xlsx
  cadence         String // weekly | monthly
  recipientEmails String // comma-separated, validated on write
  lastSentAt      DateTime?
  createdBy       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([cadence])
}

/// Single-row break-glass emergency credential. Off unless AuthSettings.breakGlassEnabled.
model BreakGlassCredential {
  id                  String    @id @default("singleton")
  passwordHash        String? // argon2id of the passphrase (null until set)
  setupTokenHash      String? // sha-256 of the one-time setup token (null once consumed)
  setupTokenExpiresAt DateTime?
  setupTokenUsedAt    DateTime?
  failedAttempts      Int       @default(0)
  lockedUntil         DateTime?
  rotatedAt           DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

/// Append-only audit trail. The app DB role is granted INSERT/SELECT only (see migration).
model AuditLog {
  id            String         @id @default(cuid())
  actorType     AuditActorType @default(system)
  actorId       String?
  actorEmail    String?
  action        String
  entityType    String?
  entityId      String?
  before        Json?
  after         Json?
  ip            String?
  userAgent     String?
  viaBreakGlass Boolean        @default(false)
  createdAt     DateTime       @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// Property hierarchy
// ---------------------------------------------------------------------------

model Property {
  id           String   @id @default(cuid())
  name         String
  addressLine1 String?
  addressLine2 String?
  city         String?
  state        String?
  zip          String?
  notes        String?
  // Legal entity / LLC that owns this property (module "portfolio"). Optional
  // free text; groups properties for per-entity financials. Stored regardless
  // of the module flag; only surfaced when "portfolio" is on.
  legalEntityName String?
  timezone     String   @default("America/New_York") // IANA tz for due-date / overdue math
  currency     String   @default("USD")
  // Financing (Financials module): fixed monthly mortgage payment and the date
  // the loan matures — used to compute net income and project post-payoff income.
  monthlyMortgageCents BigInt?
  mortgageMaturityDate DateTime?
  // Fixed yearly carrying costs, shown as monthly equivalents (÷12) in
  // Financials alongside the mortgage; included in net math. One-off
  // insurance/tax PropertyExpense rows remain separate (special assessments).
  yearlyInsuranceCents   BigInt?
  yearlyPropertyTaxCents BigInt?
  purchaseDate DateTime? // date the property/parcel was purchased (informational)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  buildings       Building[]
  units           Unit[]
  expenses        PropertyExpense[]
  maintenanceJobs MaintenanceJob[]
  recurringTasks  RecurringTask[]
  rentalApplications RentalApplication[]
  assets          Asset[]
}

// Asset / equipment registry (module "maintenance"): physical equipment
// (water heaters, HVAC, appliances) tracked per property/unit with warranty
// awareness. An operating record — never a ledger entry, never touches tenant
// balances. Standalone from MaintenanceJob (no job link in this model).
model Asset {
  id                String    @id @default(cuid())
  name              String
  category          String? // free text, e.g. "HVAC", "Appliance"
  propertyId        String
  unitId            String?
  make              String?
  model             String?
  serialNumber      String?
  installedOn       DateTime?
  warrantyExpiresOn DateTime?
  notes             String?
  active            Boolean   @default(true)
  createdBy         String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  unit     Unit?    @relation(fields: [unitId], references: [id], onDelete: SetNull)
  // Maintenance jobs that reference this asset (the job's assetId is optional and
  // clears to null if the asset is deleted — see MaintenanceJob.asset).
  jobs     MaintenanceJob[]

  @@index([propertyId])
  @@index([unitId])
}

model Building {
  id           String    @id @default(cuid())
  propertyId   String
  name         String
  description  String?
  notes        String?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  units    Unit[]
  expenses PropertyExpense[]

  @@index([propertyId])
}

model Unit {
  id                     String          @id @default(cuid())
  propertyId             String
  buildingId             String?
  unitNumber             String
  unitType               UnitType        @default(apartment)
  bedrooms               Int?
  bathrooms              Float?
  squareFeet             Int?
  defaultRentAmountCents BigInt          @default(0)
  // Serviceability axis (MANUAL): is the unit intentionally out of service?
  // Occupancy ("is it leased") is NOT stored here — it is DERIVED from whether
  // the unit has an active/month_to_month Lease (the authoritative source). This
  // split avoids the old occupancyStatus doubling. See lib/units/vacancy.ts.
  serviceStatus          ServiceStatus   @default(in_service)
  // Expected date the unit becomes available (manual override). When unset,
  // upcoming vacancy is derived from the active lease's endDate. Drives the
  // dashboard vacancy outlook — see lib/units/vacancy.ts.
  availableFromDate      DateTime?
  // Internet add-on DEFAULT for new leases on this unit (billing is
  // controlled by the lease's own internet fields).
  internetEnabled        Boolean         @default(false)
  internetFeeCents       BigInt          @default(2500)
  notes                  String?
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt

  property Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  building Building? @relation(fields: [buildingId], references: [id], onDelete: SetNull)
  leases   Lease[]
  expenses        PropertyExpense[]
  maintenanceJobs MaintenanceJob[]
  rentalApplications RentalApplication[]
  assets          Asset[]
  conditionLogs   UnitConditionLog[]
  turnoverChecklists TurnoverChecklist[]

  @@index([propertyId])
  @@index([buildingId])
}

// ---------------------------------------------------------------------------
// Tenant / lease
// ---------------------------------------------------------------------------

model Tenant {
  id                    String   @id @default(cuid())
  firstName             String
  lastName              String
  phone                 String?
  email                 String?
  mailingAddress        String?
  emergencyContactName  String?
  emergencyContactPhone String?
  smsConsent            Boolean  @default(false)
  // Email reminders: consent is absolute and independent of SMS consent.
  emailConsent          Boolean  @default(false)
  // Preferred channel for automated reminders. Delivery still requires that
  // channel's consent + contact info; falls back to skip (never cross-sends).
  reminderChannel       NotificationChannel @default(sms)
  // Email deliverability suppression (set by the /api/email/bounce webhook on a
  // hard bounce / spam complaint). null = healthy; "bounced"/"complained" =
  // suppressed, so reminder sends SKIP the email channel until staff clear it.
  // See lib/reminders/suppression.ts (the pure decision) — NOT a consent flag.
  emailDeliveryStatus   String?
  emailSuppressedAt     DateTime?
  notes                 String?
  isActive              Boolean  @default(true)
  // How this tenant prefers to pay (set by staff or by the tenant in the
  // portal). cash → staff arrange pickup; informational, never gates payments.
  preferredPaymentMethod PaymentMethod?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  leases        Lease[]
  coLeases      LeaseTenant[]
  portalAccount TenantPortalAccount?
  requests      TenantRequest[]
  trialTokens   TenantPortalTrialToken[]
  inboundMessages InboundMessage[]
  inboundEmails   InboundEmail[]
  reminderPrefs   TenantReminderPref[]

  @@index([lastName, firstName])
}

// Per-reminder-type channel override for a tenant (tenant self-serve in the
// portal). The tenant's single global `reminderChannel` is the default; a row
// here overrides ONE reminder type. `channel` is a plain string (NOT the
// NotificationChannel enum) so it can also carry "off" — mute this type — in
// addition to "sms"/"email". Effective-channel resolution + validation live in
// the DB-free lib/reminders/pref.ts. Absent row = use the global channel.
model TenantReminderPref {
  id           String   @id @default(cuid())
  tenantId     String
  reminderType String // one of the ReminderType values (rent_due_soon, …)
  channel      String // "sms" | "email" | "off"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, reminderType])
  @@index([tenantId])
}

model Lease {
  id                   String      @id @default(cuid())
  tenantId             String // primary/billing tenant; co-tenants via LeaseTenant
  unitId               String
  startDate            DateTime
  endDate              DateTime?
  // Charges are generated from the LATER of startDate and billingStartDate.
  // Lets a backdated lease (data migration) start billing at the current
  // period, with any pre-existing debt posted as an opening-balance adjustment.
  billingStartDate     DateTime?
  rentAmountCents      BigInt
  dueDay               Int         @default(1) // 1..31, clamped to last day of short months
  gracePeriodDays      Int         @default(0)
  lateFeeType          LateFeeType @default(none)
  lateFeeAmountCents   BigInt? // for fixed; daily rate for daily
  lateFeeBps           Int? // basis points for percentage (e.g. 500 = 5%)
  lateFeeMaxCents      BigInt? // optional total cap per period (daily type)
  securityDepositCents BigInt      @default(0)
  // Internet add-on billed with this lease's rent (unit fields are only the
  // default for new leases). Back-filled from the unit by migration.
  internetEnabled      Boolean     @default(false)
  internetFeeCents     BigInt      @default(2500)
  // Utilities the landlord pays for this lease (informational), e.g.
  // ["water","trash"]; free-text details in utilitiesNotes.
  utilitiesPaid        Json        @default("[]")
  utilitiesNotes       String?
  // Prorate the move-in month (start date through the day before the first
  // full period) as a partial rent_charge. Opt-in at creation so existing
  // leases are never billed retroactively.
  prorateFirstPeriod   Boolean     @default(false)
  // Scheduled rent increase: charges for periods due on/after the effective date
  // use the new amount; once the date passes, the worker rolls rentAmountCents
  // forward and clears these two fields (audited as lease.rent_increase_applied).
  scheduledRentAmountCents    BigInt?
  scheduledRentEffectiveDate  DateTime?
  status               LeaseStatus @default(draft)
  // Archived leases (terminated only) are hidden from the default lists; all
  // aggregates already exclude them via status. Never set on active leases.
  isArchived           Boolean     @default(false)
  notes                String?
  // Per-lease snapshot of the agreement clause template (with {{placeholders}})
  // this lease was issued under, frozen at creation so later edits to the
  // org-wide template (AppSettings.leaseAgreementText) never change an existing
  // lease's agreement. NULL = use the built-in DEFAULT_LEASE_AGREEMENT_TEXT
  // (pinned: a null lease never adopts a newly-set org template). A completed
  // RENEWAL re-snapshots this to the then-current org template.
  agreementText        String?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  unit          Unit          @relation(fields: [unitId], references: [id], onDelete: Restrict)
  payments      Payment[]
  ledgerEntries LedgerEntry[]
  coTenants     LeaseTenant[]
  deposits      LeaseDeposit[]
  expenses      PropertyExpense[]
  rentShares    RentShare[]
  notices       Notice[]
  inspections   Inspection[]
  conditionLogs UnitConditionLog[]
  renewalOffers LeaseRenewalOffer[]
  dispositions  DepositDisposition[]
  // Make-ready checklists worked when this lease ended (optional ref; clears to
  // null if the lease is removed — see TurnoverChecklist.lease).
  turnoverChecklists TurnoverChecklist[]

  @@index([tenantId])
  @@index([unitId])
  @@index([status])
}

/// Additional (co-)tenants on a lease beyond the primary Lease.tenantId.
model LeaseTenant {
  id        String   @id @default(cuid())
  leaseId   String
  tenantId  String
  createdAt DateTime @default(now())

  lease  Lease  @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@unique([leaseId, tenantId])
  @@index([tenantId])
}

/// Itemized deposits beyond the base security deposit (e.g. pet deposit),
/// with an explicitly non-refundable portion. Informational — not ledgered.
model LeaseDeposit {
  id                 String   @id @default(cuid())
  leaseId            String
  label              String
  amountCents        BigInt
  nonRefundableCents BigInt   @default(0)
  notes              String?
  createdAt          DateTime @default(now())

  lease Lease @relation(fields: [leaseId], references: [id], onDelete: Cascade)

  @@index([leaseId])
}

/// A move-out deposit disposition (settlement statement): itemized deductions
/// against the held deposit. On FINALIZE the net posts to the ledger — damages
/// as a positive `adjustment`, the applied deposit as a negative `credit` — so
/// the lease balance reflects the settlement; the refund is the cash side
/// (recorded here, paid out separately). Ledger writes are append-only;
/// corrections are reversals. The snapshot/total columns are filled at finalize.
model DepositDisposition {
  id       String @id @default(cuid())
  leaseId  String
  tenantId String
  /// draft | finalized
  status   String @default("draft")

  /// Refundable deposit held; defaulted from the lease, editable until finalize.
  depositHeldCents BigInt
  /// Itemized deductions: [{ "label": string, "amountCents": string(cents) }].
  deductions       Json   @default("[]")
  notes            String?

  /// Snapshots + computed totals, captured at finalize.
  balanceAtFinalizeCents BigInt?
  damagesTotalCents      BigInt?
  depositAppliedCents    BigInt?
  refundDueCents         BigInt?
  balanceOwedCents       BigInt?

  /// The ledger entries posted on finalize (loose refs, for traceability/idempotency).
  damageEntryId        String?
  depositCreditEntryId String?

  createdBy   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  finalizedAt DateTime?

  lease Lease @relation(fields: [leaseId], references: [id], onDelete: Cascade)

  @@index([leaseId])
  @@index([status])
}

// ---------------------------------------------------------------------------
// Ledger (source of financial truth)
// ---------------------------------------------------------------------------

model LedgerEntry {
  id              String          @id @default(cuid())
  leaseId         String
  tenantId        String
  entryType       LedgerEntryType
  amountCents     BigInt // signed: + increases what the tenant owes, - decreases it
  currency        String          @default("USD")
  periodKey       String? // 'YYYY-MM-DD' (due date in property tz) for rent_charge / late_fee
  effectiveDate   DateTime // economic date — drives aging / overdue
  description     String?
  sourceType      String? // 'payment' | 'charge' | 'adjustment' | 'late_fee' | ...
  sourceId        String? // e.g. Payment.id
  reversesEntryId String?
  reason          String?
  createdBy       String?
  createdAt       DateTime        @default(now())

  lease         Lease         @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  reversesEntry LedgerEntry?  @relation("LedgerReversal", fields: [reversesEntryId], references: [id])
  reversedBy    LedgerEntry[] @relation("LedgerReversal")

  // FIFO allocation links: this entry can be a charge (allocationsAsCharge)
  // or the payment that funds allocations (allocationsAsPayment).
  allocationsAsCharge  ChargeAllocation[] @relation("ChargeAllocations")
  allocationsAsPayment ChargeAllocation[] @relation("PaymentAllocations")

  @@index([leaseId, effectiveDate])
  @@index([leaseId, entryType])
  @@index([tenantId])
  @@index([reversesEntryId])
  // Partial unique indexes (rent_charge & late_fee per lease+period) are added via raw SQL
  // in the migration — @@unique cannot express the WHERE predicate.
}

/// FIFO breakdown: how much of a payment ledger entry was applied to a given charge entry.
/// Append-only: an over-applied or reversed allocation is undone by a reversing allocation.
model ChargeAllocation {
  id                   String   @id @default(cuid())
  chargeEntryId        String
  paymentEntryId       String
  amountCents          BigInt // positive amount applied to the charge
  reversesAllocationId String?
  createdAt            DateTime @default(now())

  chargeEntry        LedgerEntry        @relation("ChargeAllocations", fields: [chargeEntryId], references: [id], onDelete: Cascade)
  paymentEntry       LedgerEntry        @relation("PaymentAllocations", fields: [paymentEntryId], references: [id], onDelete: Cascade)
  reversesAllocation ChargeAllocation?  @relation("AllocationReversal", fields: [reversesAllocationId], references: [id])
  reversedBy         ChargeAllocation[] @relation("AllocationReversal")

  @@index([chargeEntryId])
  @@index([paymentEntryId])
}

model Payment {
  id               String        @id @default(cuid())
  leaseId          String
  tenantId         String
  unitId           String?
  propertyId       String?
  buildingId       String?
  // Who actually paid. null = the tenant paid. A non-null payer is a third
  // party paying on the tenant's behalf (e.g. a HUD/Section 8 housing
  // authority). Attribution only — never affects allocation or balances.
  payerId          String?
  paymentDate      DateTime
  amountCents      BigInt
  method           PaymentMethod @default(cash)
  referenceNumber  String?
  status           PaymentStatus @default(posted)
  appliedPeriodKey String? // non-authoritative hint for receipts/reports
  // Client-minted UUID; UNIQUE so a double-submit cannot create two payments.
  idempotencyKey   String        @unique
  // Attribution: set when this payment was recorded from / attached to a
  // captured inbound email (module "mailbox"). Loose ref like tenantId — never
  // affects allocation or balances.
  sourceEmailId    String?
  notes            String?
  createdBy        String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  lease Lease  @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  payer Payer? @relation(fields: [payerId], references: [id], onDelete: SetNull)

  @@index([leaseId])
  @@index([tenantId])
  @@index([paymentDate])
  @@index([status, paymentDate])
  @@index([payerId])
  @@index([sourceEmailId])
}

// ---------------------------------------------------------------------------
// Non-tenant payers (HUD / housing authority, employer, guarantor, …). A Payer
// is a party that pays on a tenant's behalf; a Payment may be attributed to one
// via Payment.payerId. Purely an attribution directory — Payers never touch the
// ledger or tenant balances. Subsidy-split expectations attach to a lease later.
// ---------------------------------------------------------------------------

enum PayerType {
  housing_authority
  employer
  guarantor
  family
  nonprofit
  other
}

/// A reusable third-party payer the org receives payments from on behalf of a
/// tenant (e.g. a Section 8 / HUD housing authority paying the HAP portion).
model Payer {
  id             String    @id @default(cuid())
  name           String
  type           PayerType @default(housing_authority)
  contactName    String?
  email          String?
  phone          String?
  mailingAddress String?
  notes          String?
  isActive       Boolean   @default(true)
  createdBy      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  payments      Payment[]
  rentShares    RentShare[]
  portalAccount PayerPortalAccount?

  @@index([isActive, name])
}

// ---------------------------------------------------------------------------
// Payer portal — a separate LOCAL auth lane (like the tenant portal) so a
// third-party payer (e.g. a housing authority) can sign in to see the leases
// they pay and what's expected/received. Email + password set via an invite
// link; sessions are opaque 256-bit cookie tokens stored only as sha-256
// hashes. Read-only: never staff Users, never OIDC, never the tenant lane.
// ---------------------------------------------------------------------------

model PayerPortalAccount {
  id      String @id @default(cuid())
  payerId String @unique
  payer   Payer  @relation(fields: [payerId], references: [id], onDelete: Cascade)

  // Login identifier, copied from the payer at invite time but owned here so
  // editing the payer record never silently changes a login.
  email String? @unique

  passwordHash String? // argon2id; null until the invite is accepted
  isActive     Boolean @default(true)

  // Invite / password-reset link (sha-256 of the raw token).
  inviteTokenHash String?   @unique
  inviteExpiresAt DateTime?

  failedLogins Int       @default(0)
  lockedUntil  DateTime?
  lastLoginAt  DateTime?

  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions PayerPortalSession[]
}

model PayerPortalSession {
  id        String             @id @default(cuid())
  accountId String
  account   PayerPortalAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  tokenHash String             @unique // sha-256 of the raw cookie token
  expiresAt DateTime
  ip        String?
  userAgent String?
  createdAt DateTime           @default(now())

  @@index([accountId])
  @@index([expiresAt])
}

/// A line of a lease's monthly rent that a particular party is expected to pay
/// (e.g. "$200 tenant portion" + "$800 HAP subsidy from Metro Housing
/// Authority"). payerId null = the tenant's portion. This is an EXPECTATION
/// overlay only: the ledger still carries the whole rent as one charge, and
/// rent shares never post entries or affect balances/allocation. Effective-dated
/// so a recertification supersedes prior splits (set endDate on the old rows).
model RentShare {
  id            String    @id @default(cuid())
  leaseId       String
  payerId       String? // null = tenant portion
  label         String
  amountCents   BigInt // expected monthly amount from this payer
  effectiveDate DateTime @default(now())
  endDate       DateTime? // exclusive; null = open-ended
  notes         String?
  createdBy     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  lease Lease  @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  payer Payer? @relation(fields: [payerId], references: [id], onDelete: SetNull)

  @@index([leaseId, effectiveDate])
  @@index([payerId])
}

// ---------------------------------------------------------------------------
// Notices (module "notices") — formal landlord notices to a tenant (late rent /
// pay-or-quit, lease violation, notice to quit, non-renewal, rent increase).
// The subject + body are SNAPSHOTTED at create so what was served is immutable
// even if templates/lease change later. Operating record, never a ledger entry.
// ---------------------------------------------------------------------------

enum NoticeType {
  late_rent
  lease_violation
  notice_to_quit
  non_renewal
  rent_increase
  general
}

enum NoticeStatus {
  draft
  served
  void
}

model Notice {
  id            String       @id @default(cuid())
  leaseId       String
  tenantId      String // the tenant the notice addresses (primary on the lease)
  type          NoticeType
  status        NoticeStatus @default(draft)
  subject       String
  body          String // rendered + editable; snapshotted
  // The deadline/effective date the notice communicates (pay-by, move-out, …).
  effectiveDate DateTime?
  servedAt      DateTime?
  servedMethod  String? // "hand" | "mail" | "posted" | "email"
  notes         String?
  createdBy     String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  lease Lease @relation(fields: [leaseId], references: [id], onDelete: Cascade)

  @@index([leaseId])
  @@index([status])
  // Hit on every tenant-portal home load (served-notice count) + activity timeline.
  @@index([tenantId, servedAt])
}

// ---------------------------------------------------------------------------
// Inspections (module "inspections") — scheduled/recorded property-condition
// inspections (move-in / move-out / routine). A move-out inspection drives a
// DEPOSIT DISPOSITION: per-item deductions on the condition checklist
// (InspectionChecklistItem.amountCents) against the lease's refundable deposit →
// computed refund. Operating records, never ledger entries:
// they don't touch tenant balances (deposits live on LeaseDeposit, not the ledger).
// ---------------------------------------------------------------------------

enum InspectionType {
  move_in
  move_out
  routine
  other
}

enum InspectionStatus {
  scheduled
  completed
  canceled
}

model Inspection {
  id           String           @id @default(cuid())
  leaseId      String
  type         InspectionType
  status       InspectionStatus @default(scheduled)
  scheduledFor DateTime?
  completedAt  DateTime?
  inspector    String?
  summary      String?
  createdBy    String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  lease Lease            @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  /// Optional template the checklist was pre-populated from (kept for reference;
  /// SetNull so deleting a template never deletes inspections).
  templateId String?
  template   InspectionTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  checklistItems InspectionChecklistItem[]

  @@index([leaseId])
  @@index([status])
  @@index([templateId])
}

/// Pass/fail/na/pending state of a single inspection CHECKLIST item (condition
/// observation).
enum InspectionChecklistStatus {
  pending // not yet assessed
  pass // acceptable condition
  fail // issue noted
  na // not applicable
}

/// Reusable inspection CHECKLIST template (e.g. "Move-in", "Move-out",
/// "Routine"): an ordered list of condition items staff can pre-populate a new
/// inspection from. Managed at Settings → Inspection templates. An operating
/// configuration record — never touches the ledger.
model InspectionTemplate {
  id          String                   @id @default(cuid())
  name        String
  type        InspectionType? // optional default inspection type this template suits
  description String?
  isActive    Boolean                  @default(true)
  createdBy   String?
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt

  items       InspectionTemplateItem[]
  inspections Inspection[]

  @@index([isActive])
}

/// One ordered line of an InspectionTemplate (e.g. "Walls & ceilings" in area
/// "Living room"). Pre-populates InspectionChecklistItem rows.
model InspectionTemplateItem {
  id         String   @id @default(cuid())
  templateId String
  label      String
  area       String? // optional room/zone, e.g. "Kitchen"
  category   String? // optional grouping, e.g. "Safety"
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())

  template InspectionTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
}

/// A single condition CHECKLIST item on one inspection: label + optional
/// area/category, a pass/fail/na status, an optional note, attached photos
/// (via UploadedDocument.inspectionChecklistItemId), and — on a move-out — an
/// optional deposit DEDUCTION amount (amountCents). The move-out disposition
/// sums these amounts. Operating record: never a ledger entry, never a balance.
model InspectionChecklistItem {
  id           String                    @id @default(cuid())
  inspectionId String
  label        String
  area         String?
  category     String?
  status       InspectionChecklistStatus @default(pending)
  note         String?
  /// Deposit deduction for this item (move-out); 0 when it isn't a deduction.
  amountCents  BigInt                    @default(0)
  sortOrder    Int                       @default(0)
  createdAt    DateTime                  @default(now())

  inspection Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)

  @@index([inspectionId])
}

enum UnitConditionPhase {
  move_in // condition when given to a tenant
  move_out // condition when left after a tenant
  turnover // vacant turnover / general (no tenant)
  other
}

/// Dated unit condition photo batch (module "inspections"): documents how a unit
/// is given to / left by a tenant, or a vacant turnover. Anchored to a UNIT (so
/// it shows historically there); the optional lease link ties it to a tenancy.
/// Photos are UploadedDocument rows (unitConditionLogId, uploadType
/// "condition_photo"). One note per batch. An OPERATING record — never a ledger
/// entry, never touches balances or deposit disposition.
model UnitConditionLog {
  id            String             @id @default(cuid())
  unitId        String
  leaseId       String? // optional tenancy link; null = unit-only (e.g. vacant turnover)
  phase         UnitConditionPhase
  conditionDate DateTime // the date the photos document (operator-set)
  note          String? // one note per batch
  createdBy     String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  unit  Unit   @relation(fields: [unitId], references: [id], onDelete: Cascade)
  lease Lease? @relation(fields: [leaseId], references: [id], onDelete: SetNull)

  @@index([unitId, conditionDate])
  @@index([leaseId])
}

// ---------------------------------------------------------------------------
// Vendors (module "vendors") — a directory of contractors/service providers
// (plumber, electrician, landscaper, …). A reference directory only; it never
// touches the ledger. Linking a vendor to maintenance jobs / expenses is a
// future enhancement.
// ---------------------------------------------------------------------------

enum VendorTrade {
  general
  plumbing
  electrical
  hvac
  landscaping
  cleaning
  appliance
  pest_control
  roofing
  other
}

model Vendor {
  id             String      @id @default(cuid())
  name           String
  trade          VendorTrade @default(general)
  contactName    String?
  email          String?
  phone          String?
  mailingAddress String?
  notes          String?
  isActive       Boolean     @default(true)
  createdBy      String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  // Loose attribution: jobs/expenses may reference a vendor (SetNull on delete).
  jobs     MaintenanceJob[]
  expenses PropertyExpense[]

  @@index([isActive, name])
}

// ---------------------------------------------------------------------------
// Phase 2 / 3 (committed now, unused in Phase 1)
// ---------------------------------------------------------------------------

/// Phase 2: digital + uploaded paper receipts.
model Receipt {
  id                String         @id @default(cuid())
  receiptNumber     String         @unique
  // Partial unique (paymentId WHERE receiptType='digital') added via raw SQL so
  // ensureReceiptForPayment is idempotent at the DB level.
  paymentId         String?
  tenantId          String?
  unitId            String?
  propertyId        String?
  receiptType       ReceiptType    @default(digital)
  amountCents       BigInt         @default(0)
  paymentDate       DateTime?
  paymentMethod     PaymentMethod?
  fileUrl           String?
  balanceAfterCents BigInt?
  sentAt            DateTime?
  sentMethod        SentMethod     @default(not_sent)
  createdBy         String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([paymentId])
  @@index([tenantId])
}

/// Phase 2: uploaded files (paper receipt photos, leases, docs).
model UploadedDocument {
  id            String     @id @default(cuid())
  tenantId      String?
  leaseId       String? // loose ref like tenantId: lease agreements, filled templates
  paymentId     String?
  receiptId     String?
  maintenanceJobId String? // loose ref: photos / invoices attached to a maintenance job
  tenantRequestId String? // loose ref: photos a tenant attached to a maintenance request
  inboundEmailId  String? // loose ref: file pulled off an inbound email (module "mailbox")
  propertyExpenseId String? // loose ref: set when an emailed invoice is posted as an expense
  unitConditionLogId String? // loose ref: photo in a unit condition batch (module "inspections")
  inspectionChecklistItemId String? // loose ref: photo on a single inspection checklist item (module "inspections")
  fileUrl       String
  fileName      String?
  fileType      String?
  fileSize      Int?
  uploadType    UploadType @default(other)
  notes         String?
  ocrText       String?
  ocrConfidence Float?
  createdBy     String?
  createdAt     DateTime   @default(now())

  @@index([tenantId])
  @@index([leaseId])
  @@index([paymentId])
  @@index([receiptId])
  @@index([maintenanceJobId])
  @@index([tenantRequestId])
  @@index([inboundEmailId])
  @@index([propertyExpenseId])
  @@index([unitConditionLogId])
  @@index([inspectionChecklistItemId])
}

/// Phase 3: SMS reminder log. The Phase-1 SMS stub records would-send rows here.
/// Append-only audit log of consent events (opt-in / opt-out) for SMS AND email.
/// One row per event with the exact consent text + version, source, and request
/// metadata — the compliance record proving when/how consent was captured. The
/// effective state stays on Tenant.smsConsent / Tenant.emailConsent; this is the
/// history behind it. `channel` distinguishes SMS from email; email rows carry
/// no phone.
model ConsentRecord {
  id            String   @id @default(cuid())
  channel       NotificationChannel @default(sms)
  phone         String?  // normalized last-10-digit key (SMS rows); null for email
  phoneRaw      String?  // as entered
  fullName      String?
  email         String?
  tenantId      String?  // matched tenant, when known
  applicationId String?  // source rental application, when applicable
  propertyUnit  String?  // optional free-text property/unit the person gave
  consent       Boolean  // true = opted in, false = opted out
  source        String   // public_sms_opt_in_form | rental_application | portal | inbound_sms_keyword | staff
  consentText   String?  // exact language shown at capture
  consentVersion String?
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime @default(now())

  @@index([phone, createdAt])
  @@index([email, createdAt])
  @@index([tenantId])
  @@index([channel, consent])
}

/// Inbound (non-keyword) SMS replies captured into a per-tenant thread staff can
/// read. STOP/START/HELP keywords are handled by the consent flow and are NOT
/// stored here. `tenantId` is matched by phone (last-10-digit key) at capture and
/// is null when no tenant matches. Operational record only — never a ledger entry,
/// never affects balances. Capture is best-effort so the webhook always 200s.
model InboundMessage {
  id          String   @id @default(cuid())
  channel     String   @default("sms")
  fromPhone   String
  body        String
  tenantId    String? // matched tenant by phone; null when unknown
  tenant      Tenant?  @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  providerSid String? // Twilio MessageSid (for dedup/traceability)
  receivedAt  DateTime @default(now())
  readAt      DateTime?

  @@index([tenantId])
  @@index([readAt])
  @@index([receivedAt])
}

/// Inbound emails captured from a configured mailbox (module "mailbox"): a
/// general staff inbox for invoices/receipts and correspondence. `body` is the
/// plain-text part only (HTML is never rendered). `tenantId` is matched by the
/// sender email at capture (null when unknown). Attachments are UploadedDocument
/// rows (inboundEmailId). An OPERATING record — never a ledger entry; posting an
/// invoice creates a human-reviewed PropertyExpense (propertyExpenseId). Capture
/// is best-effort and idempotent on `messageId` (RFC822 Message-ID, or a
/// synthetic key when absent), so re-polling never double-records.
model InboundEmail {
  id                String    @id @default(cuid())
  messageId         String    @unique
  fromEmail         String
  fromName          String?
  toAddress         String? // mailbox/alias it arrived at (future routing)
  subject           String?
  body              String // plain-text part only, capped at capture
  attachmentCount   Int       @default(0)
  status            String    @default("new") // new | archived | posted
  tenantId          String? // matched tenant by sender email; null when unknown
  tenant            Tenant?   @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  propertyExpenseId String? // set when an invoice was posted as an expense
  handledBy         String? // staff User.id who posted/archived
  handledAt         DateTime?
  receivedAt        DateTime  @default(now())
  readAt            DateTime?
  createdAt         DateTime  @default(now())

  @@index([status, receivedAt])
  @@index([tenantId])
  @@index([readAt])
}

model Reminder {
  id                String         @id @default(cuid())
  tenantId          String
  leaseId           String?
  paymentId         String?
  reminderType      ReminderType
  // 'YYYY-MM-DD' due-date key (property tz) for scheduled sends; a raw-SQL partial
  // unique on (leaseId, tenantId, reminderType, periodKey) makes worker re-runs
  // converge — per tenant, so co-tenants each get their own scheduled reminder.
  periodKey         String?
  // Channel this reminder went out on. A tenant has one preferred channel, so
  // the (lease, tenant, type, period) idempotency slot still maps to one row;
  // channel is an attribute of that row, not part of the unique key.
  channel           NotificationChannel @default(sms)
  destinationPhone  String?
  destinationEmail  String?
  messageBody       String
  status            ReminderStatus @default(queued)
  provider          String?
  providerMessageId String?
  sentBy            String?
  sentAt            DateTime?
  // Set when the provider reports terminal delivery (Twilio MessageStatus=delivered).
  deliveredAt       DateTime?
  // Provider failure detail (Twilio ErrorCode/ErrorMessage), truncated; null unless failed.
  failedReason      String?
  createdAt         DateTime       @default(now())

  // Composite covers the plain tenantId lookup (leading-column prefix) AND the
  // tenant reminder timeline ordered by createdAt.
  @@index([tenantId, createdAt])
  @@index([leaseId])
  @@index([providerMessageId])
}

// ---------------------------------------------------------------------------
// Financials module — operating expenses & financing (NOT tenant ledger rows;
// the tenant ledger stays the sole source of truth for tenant balances)
// ---------------------------------------------------------------------------

enum ExpenseCategory {
  utilities
  insurance
  maintenance
  taxes
  other
}

model PropertyExpense {
  id          String          @id @default(cuid())
  propertyId  String
  buildingId  String?
  unitId      String?
  leaseId     String? // attribute e.g. landlord-paid utilities to a tenant's lease
  category    ExpenseCategory
  amountCents BigInt
  incurredOn  DateTime
  description String?
  vendorId    String? // optional vendor paid (module "vendors")
  // Cross-module seam: e.g. sourceType="maintenance_job", sourceId=MaintenanceJob.id
  sourceType  String?
  sourceId    String?
  createdBy   String?
  createdAt   DateTime        @default(now())

  property Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  building Building? @relation(fields: [buildingId], references: [id], onDelete: SetNull)
  unit     Unit?     @relation(fields: [unitId], references: [id], onDelete: SetNull)
  lease    Lease?    @relation(fields: [leaseId], references: [id], onDelete: SetNull)
  vendor   Vendor?   @relation(fields: [vendorId], references: [id], onDelete: SetNull)

  @@index([propertyId, incurredOn])
  @@index([unitId])
  @@index([category])
  @@index([vendorId])
}

// ---------------------------------------------------------------------------
// Maintenance module — per-unit job tracker + recurring property tasks
// ---------------------------------------------------------------------------

enum MaintenanceJobStatus {
  pending
  assigned
  in_progress
  on_hold
  completed
  canceled
}

/// Triage priority for maintenance jobs (display/sort only — never gates work).
enum MaintenancePriority {
  low
  normal
  high
  urgent
}

model MaintenanceJob {
  id          String               @id @default(cuid())
  propertyId  String
  unitId      String?
  title       String
  details     String?
  status      MaintenanceJobStatus @default(pending)
  priority    MaintenancePriority  @default(normal)
  dueDate     DateTime?
  // Text consenting tenants (unit's lease, or whole property when unitId is
  // null) notifyDaysBefore days ahead of dueDate. Requires a dueDate.
  notifyTenants    Boolean @default(false)
  notifyDaysBefore Int     @default(2)
  completedAt DateTime?
  costCents   BigInt? // entered on completion; mirrored to PropertyExpense
  vendorId    String? // optional assigned vendor (module "vendors")
  // Optional link to a registered Asset (water heater, HVAC, …) this job is
  // about. Clears to null if the asset is deleted (the job history survives).
  assetId     String?
  // Loose ref to a staff User (no FK relation — keep the schema additive and
  // avoid a back-relation on User). Cleared in the app when a user is removed.
  assignedToUserId String?
  createdBy   String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  property Property            @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  unit     Unit?               @relation(fields: [unitId], references: [id], onDelete: SetNull)
  vendor   Vendor?             @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  asset    Asset?              @relation(fields: [assetId], references: [id], onDelete: SetNull)
  updates  MaintenanceUpdate[]

  @@index([propertyId, status])
  @@index([unitId, status])
  @@index([vendorId])
  @@index([assetId])
  @@index([assignedToUserId])
}

/// Threaded progress notes on a maintenance job (the "ticket" timeline). An
/// append-only log; a note may optionally record a status transition it
/// accompanied. Audited like every other mutation.
model MaintenanceUpdate {
  id        String                @id @default(cuid())
  jobId     String
  note      String
  newStatus MaintenanceJobStatus? // set when the update also changed status
  createdBy String?
  createdAt DateTime              @default(now())

  job MaintenanceJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, createdAt])
}

/// Recurring monthly upkeep (mowing, spraying, …). "Done this month" derives
/// from lastDoneOn in the property timezone; completions are audited.
model RecurringTask {
  id         String    @id @default(cuid())
  propertyId String
  title      String
  notes      String?
  active     Boolean   @default(true)
  lastDoneOn DateTime?
  // Monthly schedule (day of month, clamped to short months; null = unscheduled).
  // When notifyTenants is on, the worker texts consenting tenants of the
  // property notifyDaysBefore days ahead of each occurrence (idempotent).
  dueDay           Int?
  notifyTenants    Boolean @default(false)
  notifyDaysBefore Int     @default(2)
  createdAt  DateTime  @default(now())

  property   Property                 @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  executions RecurringTaskExecution[]

  @@index([propertyId, active])
}

// One completion record per task per property-timezone month. Re-marking a task
// in the same month updates the existing row (upsert on [taskId, periodKey]), so
// `periodKey` is the "YYYY-MM" of the month the task was done FOR. This is the
// per-occurrence execution log; it never touches tenant balances.
model RecurringTaskExecution {
  id           String   @id @default(cuid())
  taskId       String
  periodKey    String // "YYYY-MM" in the property timezone
  doneOn       DateTime @default(now())
  doneByUserId String?
  note         String?
  createdAt    DateTime @default(now())

  task RecurringTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([taskId, periodKey])
  @@index([taskId])
}

/// Lifecycle of a unit make-ready (turnover) checklist. Mirrors the
/// maintenance-job lifecycle pattern (open work -> terminal), with a status
/// helper in lib/maintenance/turnover-status.ts — never compare these literals
/// inline. `ready` means the unit is rent-ready; `open`/`in_progress` are the
/// non-terminal "still being made ready" states.
enum TurnoverChecklistStatus {
  open
  in_progress
  ready
}

/// A make-ready / turnover checklist for a unit between tenancies. An OPERATING
/// record only — it never touches the ledger or tenant balances (like
/// MaintenanceJob / RecurringTask). Optionally references the lease that ended
/// (the turnover it follows). Items live in TurnoverChecklistItem; every
/// mutation is audited. Disabling the maintenance module hides the UI but never
/// deletes this data.
model TurnoverChecklist {
  id        String                  @id @default(cuid())
  unitId    String
  // The lease whose end triggered this turnover (optional). SetNull so removing
  // the lease never deletes the make-ready record.
  leaseId   String?
  status    TurnoverChecklistStatus @default(open)
  title     String? // optional label, e.g. "Turnover — Jun 2026"
  notes     String?
  // Set when status first moves off `open` / reaches `ready` (display only).
  startedOn DateTime?
  readyOn   DateTime?
  createdBy String?
  createdAt DateTime                @default(now())
  updatedAt DateTime                @updatedAt

  unit  Unit                    @relation(fields: [unitId], references: [id], onDelete: Cascade)
  lease Lease?                  @relation(fields: [leaseId], references: [id], onDelete: SetNull)
  items TurnoverChecklistItem[]

  @@index([unitId, status])
  @@index([leaseId])
}

/// One line on a turnover checklist (e.g. "Repaint living room"). Seeded from a
/// template at checklist creation, plus staff-added custom items. `assignedToUserId`
/// is a loose ref to a staff User (no FK relation — matches MaintenanceJob, keeps
/// the schema additive and avoids a User back-relation); it is cleared/validated
/// in the app. Operating record only — never touches tenant balances.
model TurnoverChecklistItem {
  id          String   @id @default(cuid())
  checklistId String
  label       String
  area        String? // optional grouping, e.g. "Kitchen", "Exterior"
  done        Boolean  @default(false)
  notes       String?
  assignedToUserId String?
  orderIndex  Int      @default(0)
  doneAt      DateTime?
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  checklist TurnoverChecklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)

  @@index([checklistId, orderIndex])
  @@index([assignedToUserId])
}

// ---------------------------------------------------------------------------
// E-signing (built-in provider). A SigningRequest freezes the agreement TEXT
// at send time (documentText + sha256) so what was signed is immutable even
// if the lease or template changes later. Each tenant signer gets a 256-bit
// link token stored only as a sha-256 hash. The landlord side is the saved
// AppSettings signature, applied by a manager+ when the request is sent.
// ---------------------------------------------------------------------------

model SigningRequest {
  id     String @id @default(cuid())
  leaseId String
  kind   String @default("lease") // "lease" | "renewal"
  status String @default("sent") // sent | completed | canceled

  documentText   String
  documentSha256 String

  landlordName         String?
  landlordSignatureKey String? // storage key of the applied signature image
  landlordInitialsKey  String? // storage key of the applied initials image
  landlordSignedAt     DateTime?

  // UploadedDocument.id of the final signed HTML artifact (loose ref).
  signedDocumentId String?

  expiresAt   DateTime
  sentAt      DateTime  @default(now())
  completedAt DateTime?
  canceledAt  DateTime?
  createdBy   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  signers SigningSigner[]

  @@index([leaseId])
  @@index([status])
}

model SigningSigner {
  id        String         @id @default(cuid())
  requestId String
  request   SigningRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  tenantId  String
  name      String
  email     String?
  phone     String?

  // sha-256 hex of the raw link token; the raw token exists only in the sent link.
  tokenHash String @unique

  signedAt          DateTime?
  signatureKind     String? // "typed" | "drawn"
  signatureText     String? // typed-name signature
  signatureImageKey String? // storage key for a drawn signature PNG
  // Initials, captured alongside the signature when the agreement text has
  // {{tenant_initials}} markers; stamped at every marker for this signer.
  initialsKind      String? // "typed" | "drawn"
  initialsText      String?
  initialsImageKey  String?
  consentAt         DateTime?
  signerIp          String?
  signerUserAgent   String?
  lastSentAt        DateTime?
  createdAt         DateTime @default(now())

  @@index([requestId])
  @@index([tenantId])
}

/// A renewal offer: staff propose new terms (rent + end date) for an existing
/// lease; the tenant accepts by e-signing a SigningRequest with kind="renewal"
/// (reusing the whole e-sign engine — multi-signer, landlord-applied, diffed).
/// On completion the terms are APPLIED: "extend" pushes THIS lease's endDate and
/// schedules the new rent (the billing worker rolls it forward, audited);
/// "successor" mints a new lease and ends this one. An operating record — it
/// never writes ledger entries itself (rent flows through the scheduled-increase
/// path the worker already owns).
model LeaseRenewalOffer {
  id      String @id @default(cuid())
  leaseId String
  /// "extend" = same lease, new endDate + scheduled rent; "successor" = new lease.
  renewalModel String @default("extend")
  /// draft | sent | accepted | declined | expired | canceled
  status String @default("draft")

  /// Proposed terms, frozen at offer creation (integer cents).
  proposedRentAmountCents BigInt
  /// New lease end (contiguous: the term runs [currentEnd + 1 day .. proposedEndDate]).
  proposedEndDate DateTime
  /// New rent effective date = the day after the current lease's endDate.
  effectiveDate   DateTime

  /// The e-sign request carrying acceptance (kind="renewal"); set when sent.
  signingRequestId String?
  /// For "successor": the lease minted on acceptance (loose ref).
  successorLeaseId String?
  declineReason    String?

  createdBy  String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  sentAt     DateTime?
  acceptedAt DateTime?
  declinedAt DateTime?

  lease Lease @relation(fields: [leaseId], references: [id], onDelete: Cascade)

  @@index([leaseId])
  @@index([status])
  @@index([signingRequestId])
}

// ---------------------------------------------------------------------------
// Tenant portal (module "tenantPortal") — LOCAL tenant credentials, completely
// separate from the staff User table and OIDC. Tenants sign in with email +
// password (set via an invite link) or a one-time SMS code; sessions are
// opaque 256-bit cookie tokens stored only as sha-256 hashes, like e-sign
// link tokens. Disabling the module blocks logins but keeps all data.
// ---------------------------------------------------------------------------

model TenantPortalAccount {
  id       String @id @default(cuid())
  tenantId String @unique
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Login identifiers, copied from the tenant at invite time but owned by the
  // account so editing the tenant record never silently changes a login.
  email String? @unique
  phone String? @unique

  passwordHash String? // argon2id; null until the invite is accepted
  isActive     Boolean @default(true)

  // Invite / password-reset link (sha-256 of the raw token; the raw token
  // exists only inside the sent link).
  inviteTokenHash String?   @unique
  inviteExpiresAt DateTime?

  // SMS one-time code login: sha-256 of the 6-digit code, short-lived,
  // attempt-capped, resend rate-limited via otpLastSentAt.
  otpHash       String?
  otpExpiresAt  DateTime?
  otpAttempts   Int       @default(0)
  otpLastSentAt DateTime?

  failedLogins Int       @default(0)
  lockedUntil  DateTime?
  lastLoginAt  DateTime?

  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions TenantPortalSession[]
}

model TenantPortalSession {
  id        String              @id @default(cuid())
  accountId String
  account   TenantPortalAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  tokenHash String              @unique // sha-256 of the raw cookie token
  expiresAt DateTime
  ip        String?
  userAgent String?
  // Set when a STAFF user is impersonating this tenant (debug/smoke-test).
  // null = a real tenant login. Impersonation sessions show a banner, bypass the
  // account-active check, and are short-lived.
  impersonatedByUserId String?
  createdAt DateTime            @default(now())

  @@index([accountId])
  @@index([expiresAt])
}

// Single-use, short-lived "trial login" link a staff user (portal.impersonate)
// generates to open the portal AS a tenant — for debugging/smoke testing. The
// raw token lives only in the link; we store its sha-256. Consuming it mints an
// impersonation TenantPortalSession.
model TenantPortalTrialToken {
  id              String    @id @default(cuid())
  tenantId        String
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tokenHash       String    @unique
  createdByUserId String?
  expiresAt       DateTime
  usedAt          DateTime?
  createdAt       DateTime  @default(now())

  @@index([tenantId])
}

enum TenantRequestType {
  maintenance
  cash_pickup
}

enum TenantRequestStatus {
  open
  in_progress
  done
  declined
}

/// Requests tenants submit from the portal: maintenance issues and "I'll pay
/// cash — please pick it up". Operating records, NOT ledger entries — they
/// never touch tenant balances. Staff work the queue at /requests; a
/// maintenance request can be converted into a MaintenanceJob (loose ref).
model TenantRequest {
  id       String            @id @default(cuid())
  tenantId String
  tenant   Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  leaseId  String? // the lease the tenant was viewing when they submitted
  type     TenantRequestType
  message  String?

  status           TenantRequestStatus @default(open)
  maintenanceJobId String? // set when converted to a MaintenanceJob
  handledBy        String?
  handledAt        DateTime?
  resolutionNote   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
  @@index([tenantId])
}

// ---------------------------------------------------------------------------
// Rental applications (module "applications") — prospective-tenant intake.
// Submitted from the PUBLIC /apply form (no auth); staff review and optionally
// convert to a Tenant. An operating record only — never a ledger entry, never
// linked to balances. Optional property/unit interest (SetNull so deleting
// inventory keeps the application).
// ---------------------------------------------------------------------------
enum RentalApplicationStatus {
  submitted
  reviewing
  approved
  declined
  withdrawn
}

model RentalApplication {
  id                 String                  @id @default(cuid())
  firstName          String
  lastName           String
  email              String?
  phone              String?
  currentAddress     String?
  propertyId         String?
  unitId             String?
  desiredMoveInDate  DateTime?
  monthlyIncomeCents BigInt?
  employer           String?
  message            String? // applicant's free-text note
  // Display-ready snapshot of answers to operator-defined custom questions:
  // [{ label, value }] captured at submit time (history-proof vs config edits).
  customAnswers      Json?
  // Optional SMS consent captured at intake (never required to apply). Carried
  // to Tenant.smsConsent on conversion; each opt-in also writes an SmsConsentRecord.
  smsConsent         Boolean                 @default(false)
  status             RentalApplicationStatus @default(submitted)
  reviewerNotes      String? // staff-only review notes
  convertedTenantId  String? // set when converted to a Tenant
  handledBy          String? // staff user id who last acted
  handledAt          DateTime?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt

  property         Property?         @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  unit             Unit?             @relation(fields: [unitId], references: [id], onDelete: SetNull)
  backgroundChecks BackgroundCheck[]

  @@index([status, createdAt])
  @@index([unitId])
}

enum BackgroundCheckStatus {
  pending // requested; awaiting the provider's decision (async providers)
  clear // no adverse records
  consider // adverse records — needs manual (adverse-action) review
  failed // provider could not complete the check
  canceled // staff canceled before completion
}

// Tenant-screening result for a rental application. Operating record only —
// never a ledger entry, never linked to balances. PII-light: stores a normalized
// decision + short summary, not raw report contents. See
// lib/providers/background-check and lib/services/background-check.ts.
model BackgroundCheck {
  id            String                @id @default(cuid())
  applicationId String
  provider      String // provider name at request time (e.g. "stub")
  status        BackgroundCheckStatus @default(pending)
  externalId    String? // provider's reference id for this screening
  summary       String? // short human-readable finding (no raw PII)
  reportUrl     String? // link to the provider-hosted report, if any
  resultJson    Json? // normalized result payload from the provider
  requestedBy   String? // staff user id who requested (mirrors handledBy)
  requestedAt   DateTime              @default(now())
  completedAt   DateTime? // set when the status becomes terminal
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  application RentalApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId, createdAt])
}
